# Copy this file to .env.local and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API

# The service role key is SECRET. It is only ever used server-side
# (in the waitlist Server Action) and must never be exposed to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
